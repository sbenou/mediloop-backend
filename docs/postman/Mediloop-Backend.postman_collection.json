      "key": "baseUrl",
      "value": "http://localhost:8000"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "tenantId",
      "value": ""
    },
    {
      "key": "membershipId",
      "value": ""
    },
    {
      "key": "verificationToken",
      "value": ""
    },
    {
      "key": "inviteToken",
      "value": ""
    },
    {
      "key": "resetToken",
      "value": ""
    },
    {
      "key": "wearableId",
      "value": ""
    },
    {
      "key": "subscriptionId",
      "value": ""
    },
    {
      "key": "stripeCustomerId",
      "value": ""
    }
  ],
