{
  "tasks": {
    "dev": "deno run --allow-net --allow-env --allow-read --unstable-kv --unstable-cron --watch main.ts",
    "prod": "deno run --allow-net --allow-env --allow-read --unstable-kv --cached-only main.ts",
    "test": "deno test --allow-net --allow-env --allow-read --allow-run --unstable-kv ../tests/backend/",
    "setup-vault": "deno run --allow-net --allow-env --allow-read --allow-run scripts/setup-vault-launcher.ts",
    "start-dev": "deno run --allow-net --allow-env --allow-read --allow-run scripts/start-dev-launcher.ts",
    "worker": "deno run --allow-all --unstable workers/main.ts",
    "vault": "deno run --allow-net --allow-env --allow-read --allow-run scripts/vault-manager-launcher.ts",
    "debug-vault": "VAULT_URL=http://localhost:8200 VAULT_TOKEN=myroot deno run --allow-net --allow-env scripts/debug-vault.ts",
    "check-version": "deno run --allow-net scripts/check-deno-version.ts",
    "upgrade-deno": "deno upgrade",
    "migrate-tenants": "deno run --allow-net --allow-env --allow-read scripts/migrate-tenants.ts",
    "cache-backend": "deno cache ../tests/backend/*.ts",
    "verify-deno-entrypoints": "deno cache main.ts scripts/start-dev-launcher.ts scripts/start-all-services.ts scripts/setup-vault-launcher.ts scripts/vault-manager-launcher.ts scripts/apply-clinical-option-c-migrations.ts scripts/backfill-professional-personal-health.ts scripts/run-backend-tests-no-email.ts scripts/run-phase3-clinical-tests.ts",
    "test-backend": "deno test --allow-net --allow-env --allow-read --allow-run --unstable-kv ../tests/backend/",
    "test-backend-no-email": "deno run -A scripts/run-backend-tests-no-email.ts",
    "test-backend-phase3": "deno run -A scripts/run-phase3-clinical-tests.ts",
    "apply-clinical-option-c-migrations": "deno run -A scripts/apply-clinical-option-c-migrations.ts",
    "backfill-professional-personal-health": "deno run -A scripts/backfill-professional-personal-health.ts",
    "import-marketplace-catalog-csv": "deno run --allow-read --allow-write --allow-run --allow-env scripts/run-import-marketplace-catalog-csv.ts",
    "import-marketplace-catalog-csv-truncate": "deno run --allow-read --allow-write --allow-run --allow-env scripts/run-import-marketplace-catalog-csv.ts --truncate",
    "import-marketplace-catalog-csv-dev": "deno run --allow-read --allow-write --allow-run --allow-env scripts/run-import-marketplace-catalog-csv.ts --dev",
    "import-marketplace-catalog-csv-dev-truncate": "deno run --allow-read --allow-write --allow-run --allow-env scripts/run-import-marketplace-catalog-csv.ts --dev --truncate",
    "seed-clinical-demo": "deno run -A scripts/apply-seed-clinical-demo.ts",
    "seed-subscription-system": "deno run -A scripts/seedSubscriptionSystem.ts",
    "seed-subscription-plans-xlsx": "deno run -A scripts/seedSubscriptionPlansFromXlsx.ts",
    "start": "deno run --allow-run --allow-env --allow-read scripts/start-all-services.ts",

    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:redis": "docker-compose up -d redis",
    "docker:workers": "docker-compose up -d worker",
    "docker:backend": "docker-compose up -d backend",
    "docker:restart": "docker-compose restart",
    "docker:clean": "docker-compose down -v",

    "workers:install": "cd ../workers && npm install",
    "workers:dev": "cd ../workers && npm run dev",
    "workers:start": "cd ../workers && npm start",

    "dev:full": "deno task docker:redis && deno task workers:dev & deno task dev",
    "dev:backend-only": "deno task dev",
    "dev:workers-only": "deno task docker:redis && deno task workers:dev"
  },
  "imports": {
    "@std/dotenv": "https://deno.land/std@0.208.0/dotenv/mod.ts",
    "oak": "https://deno.land/x/oak@v12.6.1/mod.ts",
    "postgres": "https://deno.land/x/postgres@v0.17.0/mod.ts",
    "bcrypt": "https://deno.land/x/bcrypt@v0.4.1/mod.ts",
    "djwt": "https://deno.land/x/djwt@v3.0.1/mod.ts",
    "redis": "https://deno.land/x/redis@v0.32.1/mod.ts",
    "std": "npm:std@^0.1.40",
    "stripe": "https://esm.sh/stripe@14.21.0",
    "firebase-admin": "npm:firebase-admin@12.0.0",
    "std/": "https://deno.land/std@0.224.0/",
    "std/assert": "https://deno.land/std@0.224.0/assert/mod.ts",
    "@std/assert": "https://deno.land/std@0.224.0/assert/mod.ts"
  },
  "compilerOptions": {
    "lib": ["deno.window", "deno.unstable"],
    "strict": true
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false
  }
}
