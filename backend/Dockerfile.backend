FROM denoland/deno:1.40.0

WORKDIR /app

# Copy dependency files first (for caching)
COPY deno.json ./
COPY deno.lock* ./

# Copy source code
COPY . .

# Cache dependencies (no need to cache main.ts separately)
RUN deno cache --unstable main.ts

# Expose port 8000 (NOT 3000!)
EXPOSE 8000

# Set environment variable for port
ENV PORT=8000

# Start server
CMD ["deno", "run", "--allow-all", "--unstable", "main.ts"]