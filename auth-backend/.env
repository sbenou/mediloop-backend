
# Temporary environment variables for development
# TODO: Move to HashiCorp Vault for production

# Database connection (contains password - SECRET)
# DATABASE_URL=postgresql://your-database-url

# JWT configuration (SECRET)
# JWT_SECRET=your-super-secret-jwt-key

# OAuth provider secrets (SECRETS)
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# FRANCECONNECT_CLIENT_SECRET=your-fc-client-secret
# LUXTRUST_CLIENT_SECRET=your-luxtrust-client-secret

# Supabase secrets (during transition - SECRETS)
# SUPABASE_URL=your-supabase-url
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-key
