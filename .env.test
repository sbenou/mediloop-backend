# ============================================================================
# Test Environment Configuration
# ============================================================================
# This file contains environment variables for running automated tests
# Copy this to .env.test.local and fill in your actual values
# NEVER commit .env.test.local to version control!
# ============================================================================

# API Configuration
API_URL=http://localhost:8000

# ============================================================================
# Database Configuration (Test Database)
# ============================================================================
# IMPORTANT: Use a SEPARATE test database, NOT your production database!
# This database will have test data created and deleted during tests.
#
# Option 1: Use the same Neon database (if you're careful)
TEST_DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-small-base-a900n0vb-pooler.gwc.azure.neon.tech/neondb?sslmode=require
#
# Option 2: Create a separate test database in Neon (RECOMMENDED)
# TEST_DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-test-database.gwc.azure.neon.tech/neondb_test?sslmode=require
#
# Option 3: Use local PostgreSQL for tests
# TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mediloop_test

# ============================================================================
# Test User Credentials (for manual testing)
# ============================================================================
# These are set automatically during test runs, but you can override them
# TEST_USER_EMAIL=test-user@mediloop.com
# TEST_USER_PASSWORD=TestPassword123!@#
# TEST_VERIFICATION_TOKEN=<token from database>

# ============================================================================
# Vault Configuration (if needed for tests)
# ============================================================================
# Only needed if your tests need to read from Vault
# VAULT_ADDR=http://127.0.0.1:8200
# VAULT_TOKEN=dev-only-token

# ============================================================================
# Email Service (for testing email sending)
# ============================================================================
# RESEND_API_KEY=re_your_test_api_key
# RESEND_FROM_EMAIL=noreply@notifications.mediloop.lu

# ============================================================================
# SMS Service (for testing SMS sending)
# ============================================================================
# SMS_PROVIDER=twilio
# SMS_API_KEY=your_twilio_account_sid
# SMS_API_SECRET=your_twilio_auth_token
# SMS_SENDER_ID=+1234567890

# ============================================================================
# Frontend URL (for verification links in emails)
# ============================================================================
FRONTEND_URL=http://localhost:3000
